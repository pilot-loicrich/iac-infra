# Exemple de configuration — copier en .env et renseigner les valeurs
# Le fichier .env reel est gitignore (ne jamais commiter de secrets)

# MariaDB (base de donnees WordPress)
MARIADB_ROOT_PASSWORD=changeme_root
MARIADB_DATABASE=wordpress
MARIADB_USER=wp_user
MARIADB_PASSWORD=changeme_wp

# WordPress (connexion a la base)
WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wp_user
WORDPRESS_DB_PASSWORD=changeme_wp

# Grafana (mot de passe admin)
GF_SECURITY_ADMIN_PASSWORD=changeme_grafana

# Discord webhook pour Alertmanager (relay)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/VOTRE_ID/VOTRE_TOKEN
